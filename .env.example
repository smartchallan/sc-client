# Example environment variables for the app
# Comma-separated list of whitelisted hostnames or full URLs
# Supported formats:
#  - hostnames: app.smartchallan.com,challan.nigraani.com
#  - full URLs: https://challan.nigraani.com,http://other.example.com
VITE_WHITELABEL_HOSTS=app.smartchallan.com,https://challan.nigraani.com

# Custom assets and branding
VITE_CUSTOM_LOGO_URL=https://assets.example.com/custom-logo.png
VITE_CUSTOM_FAVICON_URL=https://assets.example.com/favicon.ico
VITE_CUSTOM_COPYRIGHT="© 2026 YourCompany. All rights reserved."

# API base (example)
# VITE_API_BASE_URL=https://api.example.com

# Per-host overrides
# You can provide per-host branding using environment variables with these patterns:
#  - VITE_<FULL_HOSTNAME>_LOGO_URL (e.g. VITE_CHALLAN_NIGRAANI_COM_LOGO_URL)
#  - VITE_<DOMAIN_TLD>_LOGO_URL (e.g. VITE_NIGRAANI_COM_LOGO_URL)
#  - VITE_<SECOND_LEVEL>_LOGO_URL (e.g. VITE_NIGRAANI_LOGO_URL)
# Same patterns apply for *_FAVICON_URL and *_COPYRIGHT
# Example for https://challan.nigraani.com/
VITE_CHALLAN_NIGRAANI_COM_LOGO_URL=https://assets.example.com/nigraani/logo.png
VITE_NIGRAANI_FAVICON_URL=https://assets.example.com/nigraani/favicon.ico
VITE_NIGRAANI_COPYRIGHT="© 2026 Nigraani Solutions. All rights reserved."
VITE_NIGRAANI_SUPPORT_EMAIL=support@nigraani.com
VITE_NIGRAANI_SUPPORT_PHONE=+91-98765-43210
