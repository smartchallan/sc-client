# User inactivity auto-logout (in seconds)
VITE_AUTO_LOGOUT_SECONDS=300
enable_gpt5_mini=true
# Whitelabel config
VITE_CUSTOM_LOGO_URL=/tspl-logo.png
VITE_CUSTOM_FAVICON_URL=https://tracking.technoton.co.in/zskins/tspl/images/favicon.ico
VITE_CUSTOM_COPYRIGHT=© Technoton Sensors Pvt. Ltd. All rights reserved.
# API configuration
# VITE_API_BASE_URL=https://server.smartchallan.com
VITE_API_BASE_URL=http://localhost:3001   
VITE_API_TIMEOUT=10000
VITE_LOGIN_ENDPOINT=/auth/login

# Expiry tracking configuration
VITE_EXPIRY_PERIOD_DAYS=30

# Support contact details for "Contact Support" quick action
VITE_SUPPORT_EMAIL=operations@smartchallan.com
VITE_SUPPORT_PHONE=+91-9315-489-988

# Banner message for expiring subscription
VITE_EXPIRY_BANNER_MSG=Your Smart Challan trial is expiring on 30 Jan 2026. Please contact sales team to continue with our Smart services.

# Challan settlement service fee configuration
# Default values used in code if these are missing:
#  - Online challan fee: 170
#  - Virtual court fee: 499
#  - Registered court fee: 899
VITE_ONLINE_CHALLAN_FEE=199
VITE_VIRTUAL_COURT_FEE=199
VITE_REGISTERED_COURT_FEE=999

# GST percentage on challan base amount (e.g., 18 for 18%)
VITE_CHALLAN_GST_PERCENT=18

# QR code image for challan settlement payments (used in Pay Challans modal)
# Provide a full image URL; falls back to a default demo QR if not set.
VITE_CHALLAN_QR_IMAGE_URL=src/assets/tspl-qr.png

# Feature flags
# When false, the Pay Challans / Challan Settlement UI is hidden
# and a "coming soon" message is shown instead.
VITE_CHALLAN_SETTLEMENT_LIVE=false
