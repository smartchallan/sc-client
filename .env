# User inactivity auto-logout (in seconds)
VITE_AUTO_LOGOUT_SECONDS=600

# UI customization
VITE_MENU_ICON_COLOR="#ee6d16"

# Client Dashboard Card Colors
VITE_CLIENT_REGISTERED_VEHICLES_COLOR=#57A5FF
VITE_CLIENT_CHALLANS_FETCHED_COLOR=#47DDBF
VITE_CLIENT_VEHICLE_RENEWALS_COLOR=#FF6B84
VITE_CLIENT_CHALLAN_AMOUNT_COLOR=#FFC167

enable_gpt5_mini=true

VITE_WHITELABEL_HOSTS=app.smartchallan.com,https://challan.nigraani.com,http://challan.nigraani.com,https://challan.eyeonfleet.com,http://challan.eyeonfleet.com

# Nigraani Whitelabel config
VITE_CHALLAN_NIGRAANI_COM_LOGO_URL=https://www.nigraani.com/wp-content/uploads/2022/06/admin-ajax.png
VITE_NIGRAANI_FAVICON_URL=https://www.nigraani.com/wp-content/uploads/2022/05/48x48.png
VITE_NIGRAANI_COPYRIGHT="© 2026 Nigraani Solutions. All rights reserved."
VITE_NIGRAANI_SUPPORT_EMAIL=business@nigraani.com
VITE_NIGRAANI_SUPPORT_PHONE=+91-8305-007-007, +91-9109-007-007

# Eyeonfleet Whitelabel config
VITE_CHALLAN_EYEONFLEET_COM_LOGO_URL=/eof-logo.png
VITE_EYEONFLEET_FAVICON_URL=
VITE_EYEONFLEET_COPYRIGHT="© 2026 Eye On Fleet. All rights reserved." 
VITE_EYEONFLEET_SUPPORT_EMAIL=info@eyeonfleet.com
VITE_EYEONFLEET_SUPPORT_PHONE=+91-8527900302, +91-8826700302

# Whitelabel config
VITE_CUSTOM_LOGO_URL=/tspl-logo.png
VITE_CUSTOM_FAVICON_URL=https://tracking.technoton.co.in/zskins/tspl/images/favicon.ico
VITE_CUSTOM_COPYRIGHT=© Technoton Sensors Pvt. Ltd. All rights reserved.


# API configuration
VITE_API_BASE_URL=https://server.smartchallan.com
# VITE_API_BASE_URL=http://localhost:3001   
VITE_API_TIMEOUT=10000
VITE_LOGIN_ENDPOINT=/auth/login

# Expiry tracking configuration
VITE_EXPIRY_PERIOD_DAYS=1

# Support contact details for "Contact Support" quick action
VITE_SUPPORT_EMAIL=operations@smartchallan.com
VITE_SUPPORT_PHONE=+91-9315-489-988

# Banner message for expiring subscription
VITE_EXPIRY_BANNER_MSG=Your Smart Challan trial is expiring on 30 Jan 2026. Please contact sales team to continue with our Smart services.

# Challan settlement service fee configuration
# Default values used in code if these are missing:
#  - Online challan fee: 170
#  - Virtual court fee: 499
#  - Registered court fee: 899
VITE_ONLINE_CHALLAN_FEE=199
VITE_VIRTUAL_COURT_FEE=199
VITE_REGISTERED_COURT_FEE=999

# GST percentage on challan base amount (e.g., 18 for 18%)
VITE_CHALLAN_GST_PERCENT=18

# QR code image for challan settlement payments (used in Pay Challans modal)
# Provide a full image URL; falls back to a default demo QR if not set.
VITE_CHALLAN_QR_IMAGE_URL=src/assets/tspl-qr.png

# Feature flags
# When false, the Pay Challans / Challan Settlement UI is hidden
# and a "coming soon" message is shown instead.
VITE_CHALLAN_SETTLEMENT_LIVE=false

# Legal acceptance popup (Terms & Conditions)
# When true, users must accept legal terms on first login
VITE_LEGAL_ACCEPTANCE_ENABLED=false

# Vehicle document upload
# When true, shows upload document option in fleet table
VITE_VEHICLE_DOCUMENT_UPLOAD_ENABLED=false

# Holi festival celebration animation
# When true, shows Holi animation on dashboard load
VITE_ENABLE_HOLI_ANIMATION=false
